<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtBarcode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:alpha="0.6"
            android:fontFamily="monospace"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="64dp"
            app:layout_constraintTop_toBottomOf="@id/txtBarcode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/errorBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="48dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/txtBarcode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/txtError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textSize="14sp"
                android:padding="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTryOcr"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="16dp"
                android:text="@string/result_try_ocr"
                android:textStyle="bold"
                android:visibility="gone"
                app:icon="@drawable/ic_text"
                app:iconGravity="textStart"
                app:cornerRadius="16dp" />

            <TextView
                android:id="@+id/txtTryOcrHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="20dp"
                android:gravity="center"
                android:textSize="12sp"
                android:alpha="0.6"
                android:text="@string/result_try_ocr_hint"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSearchGoogle"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="16dp"
                android:text="@string/result_search_google"
                android:visibility="gone"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContribute"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="16dp"
                android:text="@string/result_contribute_button"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtSourcesSearched"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="20dp"
                android:gravity="center"
                android:textSize="10sp"
                android:alpha="0.4"
                android:text="@string/result_searched_in_sources"
                android:visibility="gone" />
        </LinearLayout>

        <androidx.constraintlayout.widget.Group
            android:id="@+id/contentGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:constraint_referenced_ids="statusBadge,txtStatusLabel,txtReasons,txtReasonsHeader,txtProductName,txtBrand,productImage,txtIngredientsHeader,txtIngredients,btnScanAgain,btnBack" />

        <!-- Großes OCR-Foto (nur bei OCR-Modus sichtbar, ausserhalb der Group) -->
        <ImageView
            android:id="@+id/ocrPhotoView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:background="#22000000"
            android:visibility="gone"
            android:contentDescription="@null"
            app:layout_constraintTop_toBottomOf="@id/txtBarcode"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/statusBadge"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginTop="12dp"
            android:background="#888888"
            app:layout_constraintTop_toBottomOf="@id/ocrPhotoView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="@id/statusBadge"
            app:layout_constraintBottom_toBottomOf="@id/statusBadge"
            app:layout_constraintStart_toStartOf="@id/statusBadge"
            app:layout_constraintEnd_toEndOf="@id/statusBadge" />

        <ImageView
            android:id="@+id/productImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="16dp"
            android:scaleType="fitCenter"
            android:contentDescription="@null"
            app:layout_constraintTop_toBottomOf="@id/statusBadge"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/txtProductName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="16dp"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/statusBadge"
            app:layout_constraintStart_toEndOf="@id/productImage"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtBrand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:alpha="0.7"
            app:layout_constraintTop_toBottomOf="@id/txtProductName"
            app:layout_constraintStart_toEndOf="@id/productImage"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtReasonsHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/result_reasons_header"
            android:textSize="12sp"
            android:textStyle="bold"
            android:alpha="0.7"
            app:layout_constraintTop_toBottomOf="@id/productImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtReasons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            app:layout_constraintTop_toBottomOf="@id/txtReasonsHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtIngredientsHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/result_ingredients_header"
            android:textSize="12sp"
            android:textStyle="bold"
            android:alpha="0.7"
            app:layout_constraintTop_toBottomOf="@id/txtReasons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtIngredients"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            android:background="#1A000000"
            android:padding="12dp"
            app:layout_constraintTop_toBottomOf="@id/txtIngredientsHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScanAgain"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="@string/result_scan_again"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/txtIngredients"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:text="@string/result_back"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnScanAgain"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
