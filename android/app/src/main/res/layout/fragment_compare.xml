<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="22dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/compare_title"
            android:textSize="34sp"
            android:textStyle="bold" />

        <!-- Selection-Counter-Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="22dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/dark_card_bg">

            <FrameLayout
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:background="@drawable/circle_dark_outline">
                <TextView
                    android:id="@+id/txtCompareCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="0"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|bottom"
                    android:layout_marginBottom="14dp"
                    android:text="@string/compare_of_2"
                    android:textSize="10sp"
                    android:alpha="0.6" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/compare_select_title"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/compare_select_desc"
                    android:textSize="13sp"
                    android:textColor="@color/dark_text_secondary"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Liste der Produkte zur Auswahl (aus Watchlist/History) -->
        <TextView
            android:id="@+id/compareListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/compare_pick_from_watchlist"
            android:textSize="14sp"
            android:alpha="0.7" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/compareList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false" />

        <!-- Empty State falls keine Watchlist vorhanden -->
        <TextView
            android:id="@+id/compareEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:gravity="center"
            android:text="@string/compare_empty_hint"
            android:textSize="14sp"
            android:textColor="@color/dark_text_secondary"
            android:lineSpacingExtra="3dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDoCompare"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:text="@string/compare_start"
            android:textStyle="bold"
            android:enabled="false"
            app:cornerRadius="18dp" />
    </LinearLayout>
</ScrollView>
